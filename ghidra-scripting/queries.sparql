# # Query ideas gotten from Dr. Junjie Zhang
# Queries generated and adapted from Google's AI mode (3) and ChatGPT (1, 2, 4-8, other)

# These queries are specifically written for detecting malicious behavior in ELF (executable and linkable format) files,
# which are primarily UNIX based. Most of these queries will not work with other kinds of files,
# since the format and names of api calls will be different.

PREFIX ontology: <http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology>


# 1. Suspicious API Usage (Behavioral Indicators)

# a. detect persistent apis
# returns the base function name and the suspicious api function name
SELECT ?f ?fname ?cname
WHERE {

    ?f ontology:calls ?api .
    ?f ontology:hasName ?fname .
    ?api ontology:hasName ?cname .

    FILTER regex(?cname,
      "system|execve|popen",
      "i")
}

# b. detects networking activity through specific api calls
# returns base function name and the suspicious netowrking api function name
SELECT ?f ?fname ?name
WHERE {

    ?f ontology:calls ?api .
    ?f ontology:hasName ?fname .
    ?api ontology:hasName ?name .

    FILTER regex(?name,
      "socket|connect|send|recv|sendto|recvfrom",
      "i")
}

# c. detects other kinds of suspicious api calls
# returns the base function name and the suspicious api function name
SELECT DISTINCT ?f ?fname ?cname
WHERE {

    ?f ontology:calls ?api .
    ?f ontology:hasName ?fname .
    ?api ontology:hasName ?cname .

    FILTER regex(?cname,
      "process_vm_writev|fork|clone",
      "i")
}

# 2. Dynamic Code Execution & Self‑Modification

# a. Indirect control flow, common in shellcode loaders
# finds instructions with a jump or call opcode, with the destination operand being a register
SELECT ?instr ?opcode ?reg
WHERE {

    ?instr ontology:hasOpcode ?opcode ;
           ontology:hasDestinationOperand ?op .

    ?op ontology:hasOperandType "REGISTER" ;
        ontology:hasOperandValue ?reg .

    FILTER (?opcode IN ("JMP","CALL"))
}

# b. detect executable memory allocation through the api calls "mmap" and "mprotect"
SELECT ?f ?fname ?name
WHERE {

    ?f ontology:calls ?api .
    ?f ontology:hasName ?fname .
    ?api ontology:hasName ?name .

    FILTER regex(?name,
      "mmap|mprotect",
      "i")
}


# 3. Packed or Obfuscated Binary Detection

# a. Import sparsity vs binary size
# Gets the total count of DLLs (or external libraries) used by the program
SELECT (COUNT (*) as ?total)
WHERE {
    ?instance a ontology:DLL
}

# Gets the total number of instructions in an executable
SELECT (COUNT (*) as ?total)
WHERE {
    ?instance a ontology:Instruction
}

# b. Section entropy analysis
# this returns functions and the number of instructions based on a ratio of how many unique opcodes there are compared to the # of instructions
# The higher the ratio to 1, the more unique opcodes there are, leading to higher entropy
# It filters out any instructions that have less than 10 instructions
SELECT ?function 
    (COUNT(DISTINCT ?opcode) AS ?uniqueOpcodes) 
    (COUNT(?instruction) AS ?totalInstructions)
    ((COUNT(DISTINCT ?opcode) * 1.0 / COUNT(?instruction)) AS ?diversityRatio)

WHERE {
    ?function ontology:containsInstruction ?instruction .
    ?instruction ontology:hasOpcode ?opcode .
}
GROUP BY ?function
HAVING (?totalInstructions > 10)
ORDER BY DESC(?diversityRatio)

# c. Self‑referential decode loops (read → transform → write → repeat) 

# Looks for functions that contain both a transformation opcode and a loop/branch opcode
# This finds any self-referential decode loops, which can be an indicator of data obfuscation
# It counts how many 'suspicious' instructions are in the given function
SELECT ?function (COUNT(?inst) AS ?totalRelevantInst)
WHERE {
  ?function ontology:containsInstruction ?inst .
  ?inst ontology:hasOpcode ?opcode .
  
  BIND(LCASE(STR(?opcode)) AS ?opStr)
  
  # ensure the function has at least one TRANSFORMATION opcode
  FILTER EXISTS {
    ?function ontology:containsInstruction ?i_trans .
    ?i_trans ontology:hasOpcode ?op_trans .
    FILTER(?op_trans IN ("XOR", "ADD", "SUB", "ROR", "ROL", "NOT"))
  }
  
  # ensure the same function has at least one LOOP/BRANCH opcode
  FILTER EXISTS {
    ?function ontology:containsInstruction ?i_loop .
    ?i_loop ontology:hasOpcode ?op_loop .
    FILTER(?op_loop IN ("JNZ", "JZ", "JMP", "LOOP"))
  }

  # only count the instructions that match our overall 'suspicious' list
  FILTER(?opcode IN ("XOR", "ADD", "SUB", "ROR", "ROL", "NOT", "JNZ", "JZ", "JMP", "LOOP"))
}
GROUP BY ?function
HAVING (COUNT(?inst) >= 2) 
ORDER BY DESC(?totalRelevantInst)

# 4. Anti‑Analysis / Anti‑VM Behavior
# a. detecting ptrace api, which is a process injection technique that can often be used in linux malware
SELECT ?f
WHERE {

    ?f ontology:calls ?api .
    ?api ontology:hasName ?name .

    FILTER regex(?name,"ptrace","i")
}

# b. cpuid instructions are often used for VM detection
# TODO: maybe modify this to show what function this opcode/instruction is located in
SELECT ?instr
WHERE {
    ?instr a ontology:Instruction ;
           ontology:hasOpcode "CPUID" .
}

# 5. Privilege Escalation / System Manipulation
# a. looking for api calls that indicate permission escalation
SELECT ?f ?name
WHERE {

    ?f ontology:calls ?api .
    ?api ontology:hasName ?name .

    FILTER regex(?name,
      "setuid|setgid|capset|prctl",
      "i")
}

# 6. File System Abuse
# a. looking for api calls that can be used for file system abuse
SELECT ?f ?name
WHERE {

    ?f ontology:calls ?api .
    ?api ontology:hasName ?name .

    FILTER regex(?name,
      "open|write|unlink|chmod|chown",
      "i")
}

# 7. Command‑and‑Control (C2) Indicators
# a. checking for hard coded ip addresses, domains, or urls, which indicate C2 behavior
SELECT ?f ?value
WHERE {

    ?f ontology:calls ?api .
    ?api ontology:hasName ?name .

    FILTER regex(?name,"socket|connect|send|recv","i")

    ?f ontology:containsInstruction ?i .
    ?i ontology:hasSourceOperand ?op .
    ?op ontology:hasOperandValue ?value .

    FILTER regex(?value,"http|\\.(com|net|org)","i")
}

# 8. Cryptographic Activity

# a. getting the count of how many xor instructions are in a given function,
# large amounts often indicate custom encryption, unpacking loops, or string decoding
# only returns functions with more than 10 instances, sorts by most to least
SELECT ?f (COUNT(?xor) AS ?xorCount)
WHERE {
    ?f a ontology:Function ;
       ontology:containsInstruction ?xor .

    ?xor ontology:hasOpcode "XOR" .
}
GROUP BY ?f
HAVING (?xorCount > 10)
ORDER BY DESC(?xorCount)

# b. detecting cryptography libraries through api calls
SELECT ?f ?name
WHERE {

    ?f ontology:calls ?api .
    ?api ontology:hasName ?name .

    FILTER regex(?name,
      "aes|sha|md5|evp",
      "i")
}

# c. detecting patterns in loops that often indicate custom encryption routines
# counts how many instances of certain instructions there are, 
# and only shows functions with over 30, sorting by most to least
SELECT ?f (COUNT(?instr) AS ?bitwiseOps)
WHERE {

    ?f ontology:containsInstruction ?instr .
    ?instr ontology:hasOpcode ?op .

    FILTER (?op IN ("XOR","ROL","ROR","SHL","SHR","AND","OR"))
}
GROUP BY ?f
HAVING (?bitwiseOps > 30)
ORDER BY DESC(?bitwiseOps)

# Other
# a. detect jumps into memory, where there is a jmp or call operand on an address
# returns which function contains this instruction and what the memory address is
SELECT ?f ?fname ?instr ?value
WHERE {
    ?f ontology:containsInstruction ?instr ;
        ontology:hasName ?fname.

    ?instr ontology:hasOpcode ?opcode ;
           ontology:hasDestinationOperand ?op .

    ?op ontology:hasOperandType "ADDRESS" ;
        ontology:hasOperandValue ?value .

    FILTER (?opcode IN ("JMP","CALL"))
}

# b. detect reverse shell behavior, where a function calls 3 specific apis
SELECT ?f
WHERE {
    ?f a ontology:Function .

    ?f ontology:calls ?c1 .
    ?c1 ontology:hasName ?n1 .
    FILTER regex(?n1, "socket")

    ?f ontology:calls ?c2 .
    ?c2 ontology:hasName ?n2 .
    FILTER regex(?n2, "connect")

    ?f ontology:calls ?c3 .
    ?c3 ontology:hasName ?n3 .
    FILTER regex(?n3, "execve|system")
}

# c. Get the percentage of functions that are imported from a DLL
SELECT 
  ?totalFunctions
  ?externalFunctions
#   gets percentage based on the numbers returned from external functions and total functions
  (((?externalFunctions * 1.0) / ?totalFunctions) * 100 AS ?percentage)
#   where those numbers are returned from this sub query
WHERE {
  {
    SELECT 
    # get the count of how many functions are defined in, with the parent name containing EXTERNAL 
    # (indicating it's from a dll)
      (COUNT(?f) AS ?totalFunctions)
      (SUM(IF(CONTAINS(STR(?dll), "EXTERNAL"), 1, 0)) AS ?externalFunctions)
    WHERE {
        ?f a ontology:Function .
        ?f ontology:definedIn ?dll .
    }
  }
}