ont: a owl:Ontology .

:Label a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :definedIn ;
            owl:someValuesFrom :NamespaceSymbol ],
        [ a owl:Restriction ;
            owl:onProperty :hasName ;
