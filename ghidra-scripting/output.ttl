@prefix : <http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/> .
@prefix mkg: <https://mkg.com/data#> .
@prefix ont: <http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ont: a owl:Ontology .

:Label a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :definedIn ;
            owl:someValuesFrom :NamespaceSymbol ],
        [ a owl:Restriction ;
            owl:onProperty :hasName ;
            owl:someValuesFrom xsd:string ],
        :Symbol .

:hasParameter a owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty .

:hasType a owl:DatatypeProperty ;
    rdfs:subPropertyOf owl:topDataProperty .

:performsRole a owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty .

