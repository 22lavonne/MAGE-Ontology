@prefix : <http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/> .
@prefix ont: <http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ont: a owl:Ontology .

:Class a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :definedIn ;
            owl:someValuesFrom :NamespaceSymbol ],
        :NamespaceSymbol .

:DLL a owl:Class ;
    rdfs:subClassOf :NamespaceSymbol .

:Label a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :definedIn ;
            owl:someValuesFrom :NamespaceSymbol ],
        [ a owl:Restriction ;
            owl:onProperty :hasName ;
            owl:someValuesFrom xsd:string ],
        :Symbol .

:LocalVariable a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :definedIn ;
            owl:someValuesFrom :Function ],
        :Variable .

:Namespace a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :hasName ;
            owl:someValuesFrom xsd:string ],
        :NamespaceSymbol .

:hasParameter a owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty .

:hasType a owl:DatatypeProperty ;
    rdfs:subPropertyOf owl:topDataProperty .

:performsRole a owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty .

:ImmediateOperand a owl:Class .

:Instruction a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :hasDestinationOperand ;
            owl:someValuesFrom :Operand ],
        [ a owl:Restriction ;
            owl:onProperty :hasOpcode ;
            owl:someValuesFrom :Opcode ],
        [ a owl:Restriction ;
            owl:onProperty :hasSourceOperand ;
            owl:someValuesFrom :Operand ] .

:Opcode a owl:Class .

:Parameter a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :passesInto ;
            owl:someValuesFrom :Function ],
        :Variable .

:Register a owl:Class .

:addressOf a owl:DatatypeProperty .

:calls a owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty .

:containsInstruction a owl:ObjectProperty .

:hasAddress a owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty .

:hasDataType a owl:ObjectProperty .

:hasDestinationAddress a owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty .

:hasDestinationOperand a owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty .

:hasOpcode a owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty .

:hasOperandIndex a owl:DatatypeProperty ;
    rdfs:subPropertyOf owl:topDataProperty .

:hasPrimaryReference a owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty .

:hasReference a owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty .

:hasReferenceType a owl:DatatypeProperty .

:hasReturnType a owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty .

:hasSourceAddress a owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty .

:hasSourceOperand a owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty .

:passesInto a owl:ObjectProperty .

:DataType a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :hasName ;
            owl:someValuesFrom xsd:string ] .

:Operand a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :isA ;
            owl:someValuesFrom :Address ],
        [ a owl:Restriction ;
            owl:onProperty :isA ;
            owl:someValuesFrom :ImmediateOperand ],
        [ a owl:Restriction ;
            owl:onProperty :isA ;
            owl:someValuesFrom :Register ] .

:Reference a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :hasDestinationAddress ;
            owl:someValuesFrom :Address ],
        [ a owl:Restriction ;
            owl:onProperty :hasSourceAddress ;
            owl:someValuesFrom :Address ],
        [ a owl:Restriction ;
            owl:onProperty :hasOperandIndex ;
            owl:someValuesFrom xsd:integer ],
        [ a owl:Restriction ;
            owl:onProperty :hasReferenceType ;
            owl:someValuesFrom xsd:string ] .

:Symbol a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :hasAddress ;
            owl:someValuesFrom :Address ],
        [ a owl:Restriction ;
            owl:onProperty :hasPrimaryReference ;
            owl:someValuesFrom :Reference ],
        [ a owl:Restriction ;
            owl:onProperty :hasReference ;
            owl:someValuesFrom :Reference ] .

:returns a owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty .

:Function a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :calls ;
            owl:someValuesFrom :Function ],
        [ a owl:Restriction ;
            owl:onProperty :containsInstruction ;
            owl:someValuesFrom :Instruction ],
        [ a owl:Restriction ;
            owl:onProperty :definedIn ;
            owl:someValuesFrom :NamespaceSymbol ],
        [ a owl:Restriction ;
            owl:onProperty :hasReturnType ;
            owl:someValuesFrom :DataType ],
        [ a owl:Restriction ;
            owl:onProperty :returns ;
            owl:someValuesFrom :Parameter ],
        [ a owl:Restriction ;
            owl:onProperty :returns ;
            owl:someValuesFrom :Variable ],
        :NamespaceSymbol .

:Variable a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :hasDataType ;
            owl:someValuesFrom :DataType ] .

:hasName a owl:DatatypeProperty ;
    rdfs:subPropertyOf owl:topDataProperty .

:isA a owl:ObjectProperty .

:Address a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :addressOf ;
            owl:someValuesFrom xsd:string ] .

:definedIn a owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty .

:NamespaceSymbol a owl:Class ;
    rdfs:subClassOf :Symbol .

