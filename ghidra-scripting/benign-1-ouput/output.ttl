:Operand a owl:Class ;
    rdfs:label "Operand" ;
    rdfs:comment "operand for an instruction, tells the CPU where to use or put the data from an instruction" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :hasOperandType ;
            owl:someValuesFrom xsd:string ],
        [ a owl:Restriction ;
            owl:onProperty :hasOperandValue ;
            owl:someValuesFrom xsd:string ] .

mkg:r2 a :Operand ;
    :hasOperandType "REGISTER" ;
    :hasOperandValue "r2" .

:Reference a owl:Class ;
    rdfs:label "Reference" ;
    rdfs:comment "This class represents an identifier to a symbol, that uses a source address and destination address to do so." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :hasDestinationAddress ;
            owl:someValuesFrom :Address ],
        [ a owl:Restriction ;
            owl:onProperty :hasSourceAddress ;
            owl:someValuesFrom :Address ],
        [ a owl:Restriction ;
            owl:onProperty :hasOperandIndex ;
            owl:someValuesFrom xsd:integer ],
        [ a owl:Restriction ;
            owl:onProperty :hasReferenceType ;
            owl:someValuesFrom xsd:string ] .

mkg:r3 a :Operand ;
    :hasOperandType "DYNAMIC",
        "REGISTER" ;
    :hasOperandValue "r3" .

:Instruction a owl:Class ;
    rdfs:label "Instruction" ;
    rdfs:comment "assembly instruction gotten from the disassembly in ghidra" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :atAddress ;
            owl:someValuesFrom :Address ],
        [ a owl:Restriction ;
            owl:onProperty :hasDestinationOperand ;
            owl:someValuesFrom :Operand ],
        [ a owl:Restriction ;
            owl:onProperty :hasSourceOperand ;
            owl:someValuesFrom :Operand ],
        [ a owl:Restriction ;
            owl:onProperty :hasReturnType ;
            owl:someValuesFrom xsd:string ],
        [ a owl:Restriction ;
            owl:onProperty :hasOpcode ;
            owl:someValuesFrom xsd:string ] .

:Address a owl:Class ;
    rdfs:label "Address" ;
    rdfs:comment "Physical address in memory" ;
    owl:disjointWith :Reference .

[] a owl:AllDisjointClasses ;
    owl:members ( :Class :DLL :Function :Namespace ) .

