    rdfs:range :LocalVariable ;
    owl:inverseOf :localDefinedIn .

:hasDataType a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "hasDataType" ;
    rdfs:comment "The data type of the given variable expressed as a string" ;
    rdfs:domain :Variable ;
    rdfs:range xsd:string .

:hasDestinationAddress a owl:FunctionalProperty,
