    :hasOperandValue "[r7,#0x4]" .

:Label a owl:Class ;
    rdfs:label "Label" ;
    rdfs:comment "a string name given to a memory address, acts like a global variable in the context of this ontology" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :definedIn ;
            owl:someValuesFrom :StructuralNamespaceSymbol ],
        :Symbol ;
    owl:disjointWith :NamespaceSymbol .

mkg:_230x1 a :Operand ;
    :hasOperandType "REGISTER" ;
    :hasOperandValue "#0x1" .

