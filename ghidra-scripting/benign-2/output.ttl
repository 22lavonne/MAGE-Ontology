:atAddress a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "atAddress" ;
    rdfs:comment "specifies where an instruction is located in memory" ;
    rdfs:domain :Instruction ;
    rdfs:range :Address ;
    owl:inverseOf :memoryContainsInstruction .

:calls a owl:ObjectProperty ;
    rdfs:label "calls" ;
    rdfs:comment "specifies a calling relation between a function and another function" ;
    rdfs:domain :Function ;
    rdfs:range :Function ;
    rdfs:subPropertyOf owl:topObjectProperty .

:containsInstruction a owl:ObjectProperty ;
    rdfs:label "containsInstruction" ;
    rdfs:comment "specifies the instructions contained in a specific function" ;
    rdfs:domain :Function ;
    rdfs:range :Instruction .

:hasReturnType a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "hasReturnType" ;
    rdfs:comment "The data type of the variable returned by a function expressed as a string" ;
    rdfs:domain :Function ;
    rdfs:range xsd:string .

