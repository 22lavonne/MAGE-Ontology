@prefix : <http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix mkg: <https://mkg.com/data#> .
@prefix ont: <http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcterms:license a owl:AnnotationProperty .

ont: a owl:Ontology ;
    dcterms:license "https://creativecommons.org/licenses/by/4.0/" .

:calledBy a owl:ObjectProperty ;
    rdfs:label "calledBy" ;
    rdfs:comment "inverse of calls" ;
    rdfs:domain :Function ;
    rdfs:range :Function ;
    owl:inverseOf :calls .

:containedIn a owl:ObjectProperty ;
    rdfs:label "containedIn" ;
    rdfs:comment "inverse of containsInstruction (function containsInstruction instruction)" ;
    rdfs:domain :Instruction ;
    rdfs:range :Function ;
    owl:inverseOf :containsInstruction .

:definedInNamespace a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "definedInNamespace" ;
    rdfs:comment "specifys the objects that can be defined within a given namespace" ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Class :DLL ) ] ;
    rdfs:range :Namespace ;
    owl:inverseOf :namespaceDefines .

:defines a owl:ObjectProperty ;
    rdfs:label "defines" ;
    rdfs:comment "specifies a function or label that the given namespace defines (specifically the structural namespace symbol)" ;
    rdfs:domain :StructuralNamespaceSymbol ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Function :Label ) ] ;
    owl:inverseOf :definedIn .

:hasAddress a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "hasAddress" ;
    rdfs:comment "specifies where a given symbol is located in memory" ;
    rdfs:domain :Symbol ;
    rdfs:range :Address ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    owl:inverseOf :hasSymbol .

:isReturnedBy a owl:ObjectProperty ;
    rdfs:label "retrunedBy" ;
    rdfs:comment "inverse of returns" ;
    rdfs:domain :Parameter ;
    rdfs:range :Function ;
    owl:inverseOf :returns .

