<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/"
     xml:base="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/atAddress -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/atAddress">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/memoryContainsInstruction"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Instruction"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Address"/>
        <rdfs:comment>specifies where an instruction is located in memory</rdfs:comment>
        <rdfs:label>atAddress</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/calledBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/calledBy">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/calls"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Function"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Function"/>
        <rdfs:comment>inverse of calls</rdfs:comment>
        <rdfs:label>calledBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/calls -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/calls">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Function"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Function"/>
        <rdfs:comment>specifies a calling relation between a function and another function</rdfs:comment>
        <rdfs:label>calls</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/containedIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/containedIn">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/containsInstruction"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Instruction"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Function"/>
        <rdfs:comment>inverse of containsInstruction (function containsInstruction instruction)</rdfs:comment>
        <rdfs:label>containedIn</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/containsInstruction -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/containsInstruction">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Function"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Instruction"/>
        <rdfs:comment>specifies the instructions contained in a specific function</rdfs:comment>
        <rdfs:label>containsInstruction</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/definedIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/definedIn">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/namespaceDefines"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Class"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Function"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Label"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/NamespaceSymbol"/>
        <rdfs:comment>used for symbols defined in other namespace symbols</rdfs:comment>
        <rdfs:label>definedIn</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/defines -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/defines">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/localDefinedIn"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Function"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/LocalVariable"/>
        <rdfs:comment>used for when a function defines a local variable</rdfs:comment>
        <rdfs:label>defines</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasAddress -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasAddress">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasSymbol"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Symbol"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Address"/>
        <rdfs:comment>specifies where a given symbol is located in memory</rdfs:comment>
        <rdfs:label>hasAddress</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasDataType -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasDataType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Variable"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/DataType"/>
        <rdfs:comment>specifies what data type a variable has</rdfs:comment>
        <rdfs:label>hasDataType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasDestinationAddress -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasDestinationAddress">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/isDestinationAddressFor"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Reference"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Address"/>
        <rdfs:comment>specifies where the destination address of a given reference is</rdfs:comment>
        <rdfs:label>hasDestinationAddress</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasDestinationOperand -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasDestinationOperand">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/isDestionationOperandFor"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Instruction"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Operand"/>
        <rdfs:comment>specifies the destination operand of a given instruction</rdfs:comment>
        <rdfs:label>hasDestinationOperand</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasPrimaryReference -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasPrimaryReference">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/isPrimaryReferenceOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Symbol"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Reference"/>
        <rdfs:comment>specifies the primary reference of a given symbol (since a symbol can have multiple reference, but only one can be designated as the primary)</rdfs:comment>
        <rdfs:label>hasPrimaryReference</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasReference -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasReference">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/isReferenceFor"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Symbol"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Reference"/>
        <rdfs:comment>specifies a reference that the symbol has</rdfs:comment>
        <rdfs:label>hasReference</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasReturnType -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasReturnType">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Function"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/DataType"/>
        <rdfs:comment>specifies the return type of a function</rdfs:comment>
        <rdfs:label>hasReturnType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasSourceAddress -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasSourceAddress">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/isSourceAddressFor"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Reference"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Address"/>
        <rdfs:comment>specifies the source address of a given reference</rdfs:comment>
        <rdfs:label>hasSourceAddress</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasSourceOperand -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasSourceOperand">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/isSourceOperandFor"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Instruction"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Operand"/>
        <rdfs:comment>specifies a source operand of a given instruction (can have 0 or more)</rdfs:comment>
        <rdfs:label>hasSourceOperand</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasSymbol -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasSymbol">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Address"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Symbol"/>
        <rdfs:comment>inverse of hasAddress</rdfs:comment>
        <rdfs:label>hasSymbol</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/isDestinationAddressFor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/isDestinationAddressFor">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Address"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Reference"/>
        <rdfs:comment>inverse of hasDestinationAddress</rdfs:comment>
        <rdfs:label>isDestinationAddressFor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/isDestionationOperandFor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/isDestionationOperandFor">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Operand"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Instruction"/>
        <rdfs:comment>inverse of hasDestinationOperand</rdfs:comment>
        <rdfs:label>isDestinationOperandFor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/isPrimaryReferenceOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/isPrimaryReferenceOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Reference"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Symbol"/>
        <rdfs:comment>inverse of hasPrimaryReference</rdfs:comment>
        <rdfs:label>isPrimaryReferenceFor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/isReferenceFor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/isReferenceFor">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Reference"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Symbol"/>
        <rdfs:comment>inverse of hasReference</rdfs:comment>
        <rdfs:label>isReferenceFor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/isReturnedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/isReturnedBy">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/returns"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Parameter"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Function"/>
        <rdfs:comment>inverse of returns</rdfs:comment>
        <rdfs:label>retrunedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/isSourceAddressFor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/isSourceAddressFor">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Address"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Reference"/>
        <rdfs:comment>inverse of hasSourceAddress</rdfs:comment>
        <rdfs:label>isSourceAddressFor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/isSourceOperandFor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/isSourceOperandFor">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Operand"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Instruction"/>
        <rdfs:comment>inverse of hasSourceOperand</rdfs:comment>
        <rdfs:label>isSourceOperandFor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/localDefinedIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/localDefinedIn">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/LocalVariable"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Function"/>
        <rdfs:comment>inverse of defines</rdfs:comment>
        <rdfs:label>localDefinedIn</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/memoryContainsInstruction -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/memoryContainsInstruction">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Address"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Instruction"/>
        <rdfs:comment>inverse of atAddress</rdfs:comment>
        <rdfs:label>memoryContainsInstruction</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/namespaceDefines -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/namespaceDefines">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/NamespaceSymbol"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Class"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Function"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Label"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment>inverse of definedIn</rdfs:comment>
        <rdfs:label>namespaceDefines</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/passesInto -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/passesInto">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/takesArgument"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Parameter"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Function"/>
        <rdfs:comment>specifies what parameters or data are passed into a function</rdfs:comment>
        <rdfs:label>passesInto</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/returns -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/returns">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Function"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Parameter"/>
        <rdfs:comment>specifies the variable or data returned from a function</rdfs:comment>
        <rdfs:label>returns</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/takesArgument -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/takesArgument">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Function"/>
