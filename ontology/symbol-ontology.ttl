@prefix : <http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/> .

<http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/calls
:calls rdf:type owl:ObjectProperty ;
       rdfs:subPropertyOf owl:topObjectProperty .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/containsInstruction
:containsInstruction rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/definedIn
:definedIn rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasAddress
:hasAddress rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf owl:topObjectProperty .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasDataType
:hasDataType rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasDestinationAddress
:hasDestinationAddress rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf owl:topObjectProperty .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasDestinationOperand
:hasDestinationOperand rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf owl:topObjectProperty .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasOpcode
:hasOpcode rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasParameter
:hasParameter rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasPrimaryReference
:hasPrimaryReference rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf owl:topObjectProperty .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasReference
:hasReference rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasReturnType
:hasReturnType rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf owl:topObjectProperty .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasSourceAddress
:hasSourceAddress rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf owl:topObjectProperty .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasSourceOperand
:hasSourceOperand rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf owl:topObjectProperty .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/isA
:isA rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/passesInto
:passesInto rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/performsRole
:performsRole rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/returns
:returns rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/addressOf
:addressOf rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasName
:hasName rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf owl:topDataProperty .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasOperandIndex
:hasOperandIndex rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf owl:topDataProperty .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasReferenceType
:hasReferenceType rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/hasType
:hasType rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf owl:topDataProperty .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Address
:Address rdf:type owl:Class ;
         rdfs:subClassOf [ rdf:type owl:Restriction ;
                           owl:onProperty :addressOf ;
                           owl:someValuesFrom xsd:string
                         ] .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Class
:Class rdf:type owl:Class ;
       rdfs:subClassOf :NamespaceSymbol ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :definedIn ;
                         owl:someValuesFrom :NamespaceSymbol
                       ] .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/DLL
:DLL rdf:type owl:Class ;
     rdfs:subClassOf :NamespaceSymbol .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/DataType
:DataType rdf:type owl:Class ;
          rdfs:subClassOf [ rdf:type owl:Restriction ;
                            owl:onProperty :hasName ;
                            owl:someValuesFrom xsd:string
                          ] .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Function
:Function rdf:type owl:Class ;
          rdfs:subClassOf :NamespaceSymbol ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :calls ;
                            owl:someValuesFrom :Function
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :containsInstruction ;
                            owl:someValuesFrom :Instruction
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :definedIn ;
                            owl:someValuesFrom :NamespaceSymbol
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :hasReturnType ;
                            owl:someValuesFrom :DataType
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :returns ;
                            owl:someValuesFrom :Parameter
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :returns ;
                            owl:someValuesFrom :Variable
                          ] .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/ImmediateOperand
:ImmediateOperand rdf:type owl:Class .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Instruction
:Instruction rdf:type owl:Class ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty :hasDestinationOperand ;
                               owl:someValuesFrom :Operand
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :hasOpcode ;
                               owl:someValuesFrom :Opcode
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :hasSourceOperand ;
                               owl:someValuesFrom :Operand
                             ] .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Label
:Label rdf:type owl:Class ;
       rdfs:subClassOf :Symbol ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :definedIn ;
                         owl:someValuesFrom :NamespaceSymbol
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasName ;
                         owl:someValuesFrom xsd:string
                       ] .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/LocalVariable
:LocalVariable rdf:type owl:Class ;
               rdfs:subClassOf :Variable ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :definedIn ;
                                 owl:someValuesFrom :Function
                               ] .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Namespace
:Namespace rdf:type owl:Class ;
           rdfs:subClassOf :NamespaceSymbol ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasName ;
                             owl:someValuesFrom xsd:string
                           ] .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/NamespaceSymbol
:NamespaceSymbol rdf:type owl:Class ;
                 rdfs:subClassOf :Symbol .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Opcode
:Opcode rdf:type owl:Class .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Operand
:Operand rdf:type owl:Class ;
         rdfs:subClassOf [ rdf:type owl:Restriction ;
                           owl:onProperty :isA ;
                           owl:someValuesFrom :Address
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :isA ;
                           owl:someValuesFrom :ImmediateOperand
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :isA ;
                           owl:someValuesFrom :Register
                         ] .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Parameter
:Parameter rdf:type owl:Class ;
           rdfs:subClassOf :Variable ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :passesInto ;
                             owl:someValuesFrom :Function
                           ] .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Reference
:Reference rdf:type owl:Class ;
           rdfs:subClassOf [ rdf:type owl:Restriction ;
                             owl:onProperty :hasDestinationAddress ;
                             owl:someValuesFrom :Address
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasSourceAddress ;
                             owl:someValuesFrom :Address
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasOperandIndex ;
                             owl:someValuesFrom xsd:integer
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasReferenceType ;
                             owl:someValuesFrom xsd:string
                           ] .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Register
:Register rdf:type owl:Class .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Symbol
:Symbol rdf:type owl:Class ;
        rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty :hasAddress ;
                          owl:someValuesFrom :Address
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasPrimaryReference ;
                          owl:someValuesFrom :Reference
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasReference ;
                          owl:someValuesFrom :Reference
                        ] .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Variable
:Variable rdf:type owl:Class ;
          rdfs:subClassOf [ rdf:type owl:Restriction ;
                            owl:onProperty :hasDataType ;
                            owl:someValuesFrom :DataType
                          ] .


